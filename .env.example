# LLM API (OpenAI-compatible)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.gpt.ge/v1
LLM_MODEL=gpt-4o-mini

# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3456
ADMIN_TOKEN=change_me_for_admin_export

# Data directory (optional; Render uses /var/data with persistent disk)
# DATA_DIR=/var/data

# Optional (Render only): POST each session save to local receiver via tunnel
# 1) npm run receiver  2) npm run tunnel:receiver  3) paste URL here on Render
# DATA_WEBHOOK_URL=https://xxxx.trycloudflare.com/
